{
  "name": "@capgo/capacitor-ffmpeg",
  "version": "0.0.8",
  "description": "Exposes the FFmpeg API to Capacitor",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources",
    "ios/Tests",
    "Package.swift",
    "CapgoCapacitorFfmpeg.podspec"
  ],
  "author": "WcaleNieWolny",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://example.com.git"
  },
  "bugs": {
    "url": "https://example.com/issues"
  },
  "homepage": "https://capgo.app/docs/plugins/ffmpeg/",
  "keywords": [
    "capacitor",
    "plugin",
    "native"
  ],
  "scripts": {
    "test": "bun run test:web && bun run test:android",
    "test:web": "bun test",
    "test:android": "cd android && ./gradlew test",
    "test:ios": "xcodebuild -scheme CapgoCapacitorFfmpeg -destination 'platform=iOS Simulator,name=iPhone 17,OS=latest' test",
    "verify": "bun run verify:ios && bun run verify:android && bun run verify:web",
    "verify:ios": "xcodebuild -scheme CapgoCapacitorFfmpeg -destination generic/platform=iOS",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "bun run build && bun run test:web",
    "lint": "bun run eslint && bun run prettier -- --check && bun run swiftlint -- lint",
    "fmt": "bun run eslint -- --fix && bun run prettier -- --write && bun run swiftlint -- --fix --format",
    "eslint": "eslint . --ext ts",
    "prettier": "prettier-pretty-check \"**/*.{css,html,md,ts,js,mjs,java,json}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api CapacitorFFmpegPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "bun run clean && bun run docgen && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "bun run build",
    "check:wiring": "bun scripts/check-capacitor-plugin-wiring.mjs"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/docgen": "^0.3.1",
    "@capacitor/ios": "^8.0.0",
    "@ionic/eslint-config": "^0.4.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@types/node": "^24.10.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.6.2",
    "prettier-plugin-java": "^2.7.7",
    "rimraf": "^6.1.0",
    "rollup": "^4.53.2",
    "swiftlint": "^2.0.0",
    "typescript": "^5.9.3",
    "prettier-pretty-check": "^0.2.0"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": {
    "excluded": [
      "${PWD}/node_modules",
      "${PWD}/ios/Pods",
      "${PWD}/example-app",
      "${PWD}/.build",
      "${PWD}/.swiftpm"
    ],
    "opt_in_rules": [
      "implicitly_unwrapped_optional",
      "file_name_no_space",
      "force_unwrapping",
      "function_default_parameter_at_end",
      "lower_acl_than_parent",
      "modifier_order",
      "overridden_super_call",
      "unowned_variable_capture",
      "unused_import"
    ],
    "line_length": {
      "warning": 150,
      "ignores_function_declarations": true,
      "ignores_comments": true,
      "ignores_interpolated_strings": true,
      "ignores_urls": true
    }
  },
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
